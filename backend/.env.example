# LLM Provider: "mimo", "openai", "gemini", or "ollama"
LLM_PROVIDER=mimo
LLM_MODEL=

# MiMo via OpenGateway (used when LLM_PROVIDER=mimo)
MIMO_API_KEY=your-mimo-key
MIMO_BASE_URL=https://opengateway.gitlawb.com/v1

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key

# Google Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-key

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding provider (defaults to LLM_PROVIDER value)
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
SEED_CASE_STUDIES_ON_STARTUP=false

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Near-real-time data mode
REALTIME_MODE_REQUIRED=false
MOBILITY_REFRESH_SECONDS=60
NEWS_REFRESH_SECONDS=900
LAND_VALUE_REFRESH_SECONDS=604800
JOBS_REFRESH_SECONDS=7776000
CENSUS_REFRESH_SECONDS=2592000

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
WS_MAX_CONNECTIONS=10
SIM_TIMEOUT_MS=60000
LLM_TIMEOUT_MS=10000
